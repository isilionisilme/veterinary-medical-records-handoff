#!/usr/bin/env sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/ci/test-L1.ps1 -BaseRef HEAD
  exit $?
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ci/test-L1.ps1 -BaseRef HEAD
  exit $?
fi

if command -v pre-commit >/dev/null 2>&1; then
  echo "pre-commit hook: powershell not found, falling back to pre-commit framework"
  pre-commit run --hook-stage commit
  exit $?
fi

echo "pre-commit hook: requires PowerShell (pwsh/powershell) or pre-commit fallback." >&2
exit 1
